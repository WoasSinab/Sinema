{
  "name": "sinema",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Cinema In Your PC",
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.sinema.app",
    "productName": "sinema",
    "asar": true,
    "asarUnpack": [
      "bin/**"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "./assets/icon.ico"
    }
  }
}
